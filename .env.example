SUPABASE_URL=
SUPABASE_SERVICE_KEY=
FOOTBALL_DATA_API_KEY=        # historical results/fixtures source (optional; offline modeling works without it)
DRY_RUN=true
CLV_VALIDATION_PASSED=false     # set true ONLY after historical positive-CLV gate passes
MODEL_VERSION=v0

# Edge / staking
EDGE_THRESHOLD=0.03
KELLY_FRACTION=0.25
KELLY_CAP=0.05
BANKROLL=1000
MIN_LIQUIDITY_USD=5000
DEVIG_METHOD=shin             # multiplicative | power | shin

# Model (Dixon-Coles + Elo prior)
BASE_GOALS=2.6                # baseline total expected goals for an even match
ELO_GOAL_SCALE=150            # Elo points per 1 goal of expected supremacy
HOME_ADVANTAGE_ELO=65         # Elo bump for the home side (0 at neutral venues)
DC_RHO=-0.08                  # Dixon-Coles low-score correction
DC_DECAY=0.003                # per-day time decay for fitting
MAX_GOALS=10                  # scoreline matrix size per side

# Polymarket CLOB V2 (global crypto-native stack — NOT polymarket.us)
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYMARKET_DATA_HOST=https://data-api.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=         # EOA hex key for L1/L2 auth — never commit
POLYMARKET_API_KEY=             # optional pre-derived L2 creds
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_SIGNATURE_TYPE=2     # 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE, 3=POLY_1271 (deposit)
POLYMARKET_FUNDER=                # proxy/Safe/deposit wallet holding pUSD (if not EOA)
POLYMARKET_BANKROLL_PUSD=0      # bankroll for Kelly fraction → pUSD sizing
POLYMARKET_ORDER_TYPE=GTC       # GTC | GTD | FOK | FAK
POLYMARKET_PRICE_SLIPPAGE_BPS=50
