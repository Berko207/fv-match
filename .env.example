SUPABASE_URL=
SUPABASE_SERVICE_KEY=
FOOTBALL_DATA_API_KEY=        # historical results/fixtures source (optional; offline modeling works without it)
DRY_RUN=true
MODEL_VERSION=v0

# Edge / staking
EDGE_THRESHOLD=0.03
KELLY_FRACTION=0.25
KELLY_CAP=0.05
BANKROLL=1000
MIN_LIQUIDITY_USD=5000
DEVIG_METHOD=shin             # multiplicative | power | shin

# Model (Dixon-Coles + Elo prior)
BASE_GOALS=2.6                # baseline total expected goals for an even match
ELO_GOAL_SCALE=150            # Elo points per 1 goal of expected supremacy
HOME_ADVANTAGE_ELO=65         # Elo bump for the home side (0 at neutral venues)
DC_RHO=-0.08                  # Dixon-Coles low-score correction
DC_DECAY=0.003                # per-day time decay for fitting
MAX_GOALS=10                  # scoreline matrix size per side
